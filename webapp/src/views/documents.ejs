<%- include("partials/header") %>

<section class="panel">
  <div class="panel-heading">
    <h2>Shared documents</h2>
    <span>Contracts, reports, and exports</span>
  </div>
  <div class="doc-grid">
    <% files.forEach((file) => { %>
      <a class="doc-card" href="/download?file=<%= file %>">
        <strong><%= file.split("/").pop() %></strong>
        <span><%= file %></span>
      </a>
    <% }) %>
  </div>
</section>

<%- include("partials/footer") %>
